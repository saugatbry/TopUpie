# Upstash Redis (Vercel KV) — optional but recommended for persistent caching
# Get these from https://console.upstash.com or Vercel KV dashboard
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# OR if using Vercel KV integration, the env vars are auto-injected:
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
